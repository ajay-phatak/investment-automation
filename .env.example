# Copy this file to .env and fill in your values. .env is gitignored — never
# commit real keys. Values exported in your shell override this file.

# Long-lived subscription auth token for unattended runs. Generate with
#   claude setup-token   (requires a Claude subscription; billed to it, not API
# credits). Lasts far longer than the interactive login, so weekend runs don't
# die when the session token expires. When set, the key-stripped CLI uses this.
# Treat it like a password — it's a real credential. Leave empty to fall back to
# the interactive `claude` /login session.
CLAUDE_CODE_OAUTH_TOKEN=
# The token above is opaque, so record the expiry date setup-token gave you
# (YYYY-MM-DD; ~1 year out). Reports show a countdown to it and the Friday
# pre-flight warns within 30 days. Update both lines whenever you regenerate.
CLAUDE_CODE_OAUTH_TOKEN_EXPIRES=

# Alpaca market data (recommended; free paper/read-only keys work).
# Without these the script falls back to yfinance for everything.
ALPACA_API_KEY=
ALPACA_API_SECRET=
# "iex" (default, ~15min delayed, free) or "sip" (paid)
ALPACA_FEED=iex

# Optional: absolute path to an Obsidian vault. When set, every saved report is
# also written into "<vault>/claude reports/market research agent/" so it shows
# up in Obsidian automatically. Leave empty to disable.
OBSIDIAN_VAULT_DIR=

# Optional: push alerts for auth failures (weekend run blocked) and the weekday
# pre-flight warning. Either/both. Without them, alerts still go to the log, the
# _auth_alert.flag sentinel, and a best-effort Windows desktop balloon.
#   NOTIFY_NTFY_TOPIC: a private, RANDOM ntfy.sh topic (or a full URL). Install
#   the ntfy app and subscribe to the same topic to get phone pushes. Keep the
#   topic secret — anyone who knows it can read/post. Never commit it.
NOTIFY_NTFY_TOPIC=
#   NOTIFY_WEBHOOK_URL: a Slack/Discord/generic incoming-webhook URL.
NOTIFY_WEBHOOK_URL=
