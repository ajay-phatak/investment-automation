# Copy this file to .env and fill in your values. .env is gitignored — never
# commit real keys. Values exported in your shell override this file.

# Alpaca market data (recommended; free paper/read-only keys work).
# Without these the script falls back to yfinance for everything.
ALPACA_API_KEY=
ALPACA_API_SECRET=
# "iex" (default, ~15min delayed, free) or "sip" (paid)
ALPACA_FEED=iex

# Optional: absolute path to an Obsidian vault. When set, every saved report is
# also written into "<vault>/claude reports/market research agent/" so it shows
# up in Obsidian automatically. Leave empty to disable.
OBSIDIAN_VAULT_DIR=
